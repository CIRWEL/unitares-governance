#!/usr/bin/env bash
# UNITARES Governance Plugin — SessionStart hook
# Thin Claude adapter: onboard, cache continuity, inject light context
set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve plugin root (parent of hooks/)
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# ---------------------------------------------------------------------------
# Resolve repo-local helper paths across plugin and monorepo layouts
# ---------------------------------------------------------------------------
DEFAULTS_FILE=""
for candidate in \
  "${PLUGIN_ROOT}/config/defaults.env" \
  "${PLUGIN_ROOT}/config/client/defaults.env"
do
  if [[ -f "${candidate}" ]]; then
    DEFAULTS_FILE="${candidate}"
    break
  fi
done

SESSION_CACHE_HELPER=""
for candidate in \
  "${PLUGIN_ROOT}/scripts/session_cache.py" \
  "${PLUGIN_ROOT}/scripts/client/session_cache.py"
do
  if [[ -f "${candidate}" ]]; then
    SESSION_CACHE_HELPER="${candidate}"
    break
  fi
done

FRESHNESS_WARNING_HELPER=""
for candidate in \
  "${PLUGIN_ROOT}/scripts/_freshness_warning.py" \
  "${PLUGIN_ROOT}/scripts/client/_freshness_warning.py"
do
  if [[ -f "${candidate}" ]]; then
    FRESHNESS_WARNING_HELPER="${candidate}"
    break
  fi
done

# ---------------------------------------------------------------------------
# Load defaults, then let env vars override
# ---------------------------------------------------------------------------
SERVER_URL_OVERRIDE="${UNITARES_SERVER_URL-}"
AGENT_PREFIX_OVERRIDE="${UNITARES_AGENT_PREFIX-}"

if [[ -n "${DEFAULTS_FILE}" ]]; then
  # shellcheck source=/dev/null
  source "${DEFAULTS_FILE}"
fi

if [[ -n "${SERVER_URL_OVERRIDE}" ]]; then
  UNITARES_SERVER_URL="${SERVER_URL_OVERRIDE}"
fi
if [[ -n "${AGENT_PREFIX_OVERRIDE}" ]]; then
  UNITARES_AGENT_PREFIX="${AGENT_PREFIX_OVERRIDE}"
fi

SERVER_URL="${UNITARES_SERVER_URL:-http://localhost:8767}"
AGENT_PREFIX="${UNITARES_AGENT_PREFIX:-claude}"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
escape_for_json() {
  local text="$1"
  python3 -c "
import json, sys
print(json.dumps(sys.argv[1])[1:-1])
" "$text"
}

call_tool() {
  local tool_name="$1"
  local arguments="$2"
  local curl_args=(
    -s
    --max-time 10
    -X POST "${SERVER_URL}/v1/tools/call"
    -H "Content-Type: application/json"
  )
  if [[ -n "${UNITARES_HTTP_API_TOKEN:-}" ]]; then
    curl_args+=(-H "Authorization: Bearer ${UNITARES_HTTP_API_TOKEN}")
  fi
  curl "${curl_args[@]}" \
    -d "{\"name\": \"${tool_name}\", \"arguments\": ${arguments}}" 2>/dev/null || echo ""
}

parse_tool_response() {
  # MCP wraps tool results: result.content[0].text is a JSON string
  local raw="$1"
  python3 -c "
import json, sys
try:
    outer = json.loads(sys.argv[1])
    # Navigate MCP wrapper: result -> content[0] -> text (JSON string)
    if 'result' in outer:
        content = outer['result']
        if isinstance(content, dict) and 'content' in content:
            text = content['content'][0]['text']
            inner = json.loads(text)
            print(json.dumps(inner))
        else:
            print(json.dumps(content))
    else:
        print(json.dumps(outer))
except Exception:
    print('{}')
" "$raw"
}

json_get() {
  local raw="$1"
  local key="$2"
  python3 -c "
import json, sys
try:
    data = json.loads(sys.argv[1])
    value = data.get(sys.argv[2], '')
    if isinstance(value, (dict, list)):
        import json as _json
        print(_json.dumps(value))
    else:
        print(value if value is not None else '')
except Exception:
    print('')
" "$raw" "$key"
}

# ---------------------------------------------------------------------------
# Derive agent name
# ---------------------------------------------------------------------------
PROJECT_BASENAME="$(basename "${PWD}")"
if [[ "${PWD}" == "${HOME}" || -z "${PROJECT_BASENAME}" || "${PROJECT_BASENAME}" == "/" ]]; then
  AGENT_NAME="$(hostname -s)"
else
  AGENT_NAME="${PROJECT_BASENAME}"
fi

# ---------------------------------------------------------------------------
# Read hook input — Claude Code passes session metadata as JSON on stdin.
# We use session_id as the cache slot key so N parallel claude processes in
# the same workspace each get their own identity rather than racing on a
# single .unitares/session.json (operator-flagged "multiple Claude agents
# sharing UUID" on 2026-04-14).
# ---------------------------------------------------------------------------
HOOK_INPUT=""
if [[ ! -t 0 ]]; then
  HOOK_INPUT=$(cat 2>/dev/null) || true
fi
SESSION_SLOT=""
if [[ -n "${HOOK_INPUT}" ]]; then
  SESSION_SLOT=$(printf '%s' "${HOOK_INPUT}" | python3 -c "
import json, sys
try:
    print(json.load(sys.stdin).get('session_id') or '')
except Exception:
    print('')
" 2>/dev/null || true)
fi

# ---------------------------------------------------------------------------
# Load a short reference snippet (available regardless of server status)
# ---------------------------------------------------------------------------
SKILL_CONTENT=""
SKILL_FILE="${PLUGIN_ROOT}/skills/governance-fundamentals/SKILL.md"
if [[ -f "${SKILL_FILE}" ]]; then
  SKILL_CONTENT="$(sed -n '1,80p' "${SKILL_FILE}")"
fi

# ---------------------------------------------------------------------------
# Check skill freshness — warn if last_verified is stale
# ---------------------------------------------------------------------------
if [[ -n "${SKILL_CONTENT}" && -n "${FRESHNESS_WARNING_HELPER}" ]]; then
  FRESHNESS_WARNING=$(python3 "${FRESHNESS_WARNING_HELPER}" "${SKILL_CONTENT}" 2>/dev/null || true)

  if [[ -n "${FRESHNESS_WARNING}" ]]; then
    SKILL_CONTENT="${FRESHNESS_WARNING}

${SKILL_CONTENT}"
  fi
fi

# ---------------------------------------------------------------------------
# Ping governance server
# ---------------------------------------------------------------------------
HEALTH_STATUS=$(curl -s --max-time 3 "${SERVER_URL}/health" 2>/dev/null || echo "")

if [[ -z "${HEALTH_STATUS}" ]]; then
  # -------------------------------------------------------------------------
  # Server unreachable — inject skill content only
  # -------------------------------------------------------------------------
  CONTEXT="UNITARES Governance: OFFLINE (${SERVER_URL} unreachable). Agent not onboarded. Governance tools may be unavailable."
  if [[ -n "${SKILL_CONTENT}" ]]; then
    CONTEXT="${CONTEXT}\n\n--- Governance Fundamentals (reference) ---\n${SKILL_CONTENT}"
  fi

  ESCAPED_CONTEXT="$(escape_for_json "${CONTEXT}")"
  cat <<ENDJSON
{
  "additional_context": "${ESCAPED_CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ESCAPED_CONTEXT}"
  }
}
ENDJSON
  exit 0
fi

# ---------------------------------------------------------------------------
# Server reachable — onboard agent via Python helper
#
# The helper owns cache-read → onboard → trajectory_required retry → cache-write.
# On failure it leaves the existing cache untouched so a good prior session
# cannot be clobbered by a transient error.
# ---------------------------------------------------------------------------
ONBOARD_HELPER=""
for candidate in \
  "${PLUGIN_ROOT}/scripts/onboard_helper.py" \
  "${PLUGIN_ROOT}/scripts/client/onboard_helper.py"
do
  if [[ -f "${candidate}" ]]; then
    ONBOARD_HELPER="${candidate}"
    break
  fi
done

if [[ -z "${ONBOARD_HELPER}" ]]; then
  CONTEXT="UNITARES Governance: ONLINE but onboard_helper.py missing from plugin.
Check plugin installation integrity."
  ESCAPED_CONTEXT="$(escape_for_json "${CONTEXT}")"
  cat <<ENDJSON
{
  "additional_context": "${ESCAPED_CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ESCAPED_CONTEXT}"
  }
}
ENDJSON
  exit 0
fi

ONBOARD_RESULT=$(UNITARES_SERVER_URL="${SERVER_URL}" python3 "${ONBOARD_HELPER}" \
    --server-url "${SERVER_URL}" \
    --name "${AGENT_NAME}" \
    --model-type "claude-code" \
    --workspace "${PWD}" \
    --slot "${SESSION_SLOT}" 2>/dev/null)

ONBOARD_STATUS=$(python3 -c "
import json, sys
try:
    print(json.loads(sys.argv[1]).get('status', 'unknown'))
except Exception:
    print('unknown')
" "${ONBOARD_RESULT}")

if [[ "${ONBOARD_STATUS}" != "ok" ]]; then
  # Onboard failed; surface context so the operator can recover manually.
  ONBOARD_ERROR=$(python3 -c "
import json, sys
try:
    data = json.loads(sys.argv[1])
    err = data.get('error', 'unknown error')
    reason = data.get('recovery_reason', '')
    used_force = data.get('used_force_new', False)
    parts = [err]
    if reason:
        parts.append(f'recovery: {reason}')
    if used_force:
        parts.append('retried with force_new=true')
    print(' | '.join(parts))
except Exception:
    print('unknown error')
" "${ONBOARD_RESULT}")

  CONTEXT="UNITARES Governance: ONLINE but onboard failed
Reason: ${ONBOARD_ERROR}

Run /governance-start to attempt a manual onboard, or check server logs."
  if [[ -n "${SKILL_CONTENT}" ]]; then
    CONTEXT="${CONTEXT}

--- Governance Fundamentals (reference) ---
${SKILL_CONTENT}"
  fi

  ESCAPED_CONTEXT="$(escape_for_json "${CONTEXT}")"
  cat <<ENDJSON
{
  "additional_context": "${ESCAPED_CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ESCAPED_CONTEXT}"
  }
}
ENDJSON
  exit 0
fi

# Onboard succeeded — extract fields for the rest of the script.
AGENT_UUID=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('uuid',''))" "${ONBOARD_RESULT}")
AGENT_ID=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('agent_id',''))" "${ONBOARD_RESULT}")
CLIENT_SESSION_ID=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('client_session_id',''))" "${ONBOARD_RESULT}")
CONTINUITY_TOKEN=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('continuity_token',''))" "${ONBOARD_RESULT}")
SESSION_RESOLUTION_SOURCE=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('session_resolution_source',''))" "${ONBOARD_RESULT}")
CONTINUITY_TOKEN_SUPPORTED=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('continuity_token_supported',''))" "${ONBOARD_RESULT}")
# used_force_new removed — force_new is never automatic (per 718ccd3 invariant)

# Post-onboard check-in: anchor EISV baseline. Fire-and-forget; the
# shared helper swallows errors and logs to ~/.unitares/checkins.log.
if [[ -n "${CLIENT_SESSION_ID}" ]]; then
  WORKSPACE_BASENAME=$(basename "${PWD}")
  BRANCH=$(git -C "${PWD}" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "no-git")
  CHECKIN_SUMMARY="Session initialized for ${WORKSPACE_BASENAME} on branch ${BRANCH}"
  python3 "${PLUGIN_ROOT}/scripts/checkin.py" \
    --event session_start \
    --response-text "${CHECKIN_SUMMARY}" \
    --complexity 0.1 \
    --confidence 0.9 \
    --client-session-id "${CLIENT_SESSION_ID}" \
    --continuity-token "${CONTINUITY_TOKEN}" \
    --uuid "${AGENT_UUID}" \
    --slot "${SESSION_SLOT:-default}" \
    >/dev/null 2>&1 || true
fi

# Stamp updated_at on the cache the helper wrote (keeps the existing invariant).
if [[ -n "${SESSION_CACHE_HELPER}" ]]; then
  python3 "${SESSION_CACHE_HELPER}" \
    set session \
    --workspace "${PWD}" \
    --merge \
    --stamp \
    --json "{}" >/dev/null 2>&1 || true
fi

# ---------------------------------------------------------------------------
# Fetch a light read of current state
# ---------------------------------------------------------------------------
EISV_SUMMARY=""
if [[ -n "${CLIENT_SESSION_ID}" ]]; then
  METRICS_RAW=$(call_tool "get_governance_metrics" "{\"client_session_id\": \"${CLIENT_SESSION_ID}\"}")
  METRICS_PARSED=$(parse_tool_response "${METRICS_RAW}")

  EISV_SUMMARY=$(python3 -c "
import json, sys
try:
    data = json.loads(sys.argv[1])
    e = data.get('E', '?')
    i = data.get('I', '?')
    s = data.get('S', '?')
    v = data.get('V', '?')
    verdict = data.get('verdict', '')
    parts = [f'E={e} I={i} S={s} V={v}']
    if verdict:
        parts.append(f'verdict={verdict}')
    print(' | '.join(parts))
except Exception:
    print('EISV fetch failed')
" "${METRICS_PARSED}")
fi

# ---------------------------------------------------------------------------
# Build context output
# ---------------------------------------------------------------------------
AGENT_ID_SNIPPET=""
if [[ -n "${AGENT_ID}" ]]; then
  AGENT_ID_SNIPPET="${AGENT_ID:0:8}"
fi

CONTEXT="UNITARES Governance: ONLINE
Agent: ${AGENT_NAME} (${AGENT_ID_SNIPPET}...)
UUID: ${AGENT_UUID}
Session: ${CLIENT_SESSION_ID:0:12}..."

if [[ -n "${EISV_SUMMARY}" ]]; then
  CONTEXT="${CONTEXT}
EISV: ${EISV_SUMMARY}"
fi

# No force_new NOTE — force_new is never automatic. Trajectory failures
# are surfaced as onboard_failed with clear recovery guidance.

CONTEXT="${CONTEXT}

On your first governance MCP tool call, pass agent_uuid=\"${AGENT_UUID}\" to bind your MCP session to this identity.

Preferred workflow:
- use meaningful check-ins, not per-edit check-ins
- use /checkin after a real milestone
- use /diagnose, identity(), or health_check() when behavior looks wrong"

if [[ -n "${SKILL_CONTENT}" ]]; then
  CONTEXT="${CONTEXT}

--- Governance Fundamentals (excerpt) ---
${SKILL_CONTENT}"
fi

ESCAPED_CONTEXT="$(escape_for_json "${CONTEXT}")"

cat <<ENDJSON
{
  "additional_context": "${ESCAPED_CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ESCAPED_CONTEXT}"
  }
}
ENDJSON
