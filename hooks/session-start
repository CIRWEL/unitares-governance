#!/usr/bin/env bash
# UNITARES Governance Plugin — SessionStart hook
#
# Identity-honesty Part C (Session C, 2026-04-17):
# This hook no longer creates an identity on the agent's behalf. It confirms
# governance is reachable, loads the fundamentals skill, and emits context
# instructing the agent to make its own first MCP tool call (onboard /
# identity / bind_session). The post-identity PostToolUse hook captures the
# response and writes the session cache.
#
# See docs/specs/2026-04-17-session-start-stops-creating-identities.md
# in the unitares repo for the architectural rationale.
set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve plugin root and helpers
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

DEFAULTS_FILE=""
for candidate in \
  "${PLUGIN_ROOT}/config/defaults.env" \
  "${PLUGIN_ROOT}/config/client/defaults.env"
do
  if [[ -f "${candidate}" ]]; then
    DEFAULTS_FILE="${candidate}"
    break
  fi
done

FRESHNESS_WARNING_HELPER=""
for candidate in \
  "${PLUGIN_ROOT}/scripts/_freshness_warning.py" \
  "${PLUGIN_ROOT}/scripts/client/_freshness_warning.py"
do
  if [[ -f "${candidate}" ]]; then
    FRESHNESS_WARNING_HELPER="${candidate}"
    break
  fi
done

# Preserve operator-provided env overrides across defaults.env sourcing.
SERVER_URL_OVERRIDE="${UNITARES_SERVER_URL-}"
if [[ -n "${DEFAULTS_FILE}" ]]; then
  # shellcheck source=/dev/null
  source "${DEFAULTS_FILE}"
fi
if [[ -n "${SERVER_URL_OVERRIDE}" ]]; then
  UNITARES_SERVER_URL="${SERVER_URL_OVERRIDE}"
fi

SERVER_URL="${UNITARES_SERVER_URL:-http://localhost:8767}"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
escape_for_json() {
  python3 -c "
import json, sys
print(json.dumps(sys.argv[1])[1:-1])
" "$1"
}

# ---------------------------------------------------------------------------
# Load a short reference snippet (available regardless of server status)
# ---------------------------------------------------------------------------
SKILL_CONTENT=""
SKILL_FILE="${PLUGIN_ROOT}/skills/governance-fundamentals/SKILL.md"
if [[ -f "${SKILL_FILE}" ]]; then
  SKILL_CONTENT="$(sed -n '1,80p' "${SKILL_FILE}")"
fi

if [[ -n "${SKILL_CONTENT}" && -n "${FRESHNESS_WARNING_HELPER}" ]]; then
  FRESHNESS_WARNING=$(python3 "${FRESHNESS_WARNING_HELPER}" "${SKILL_CONTENT}" 2>/dev/null || true)
  if [[ -n "${FRESHNESS_WARNING}" ]]; then
    SKILL_CONTENT="${FRESHNESS_WARNING}

${SKILL_CONTENT}"
  fi
fi

# ---------------------------------------------------------------------------
# Workspace-local continuity probe (./.unitares/session.json in CWD).
#
# IMPORTANT: we deliberately do NOT enumerate ~/.unitares/session-*.json.
# That glob produced an unfiltered cross-instance UUID menu, which — paired
# with an `identity(agent_uuid=..., resume=true)` suggestion — invited
# fresh agents to pattern-match on model name and resume into other
# instances' identities. See KG bug 2026-04-20T00:09:51 and the
# identity-honesty invariants in operator memory.
#
# The workspace-local cache, by contrast, is owned by the agent that
# previously ran in THIS directory (written by the post-identity hook).
# Surfacing its existence — but NOT the bare UUID — is ownership-grounded.
# ---------------------------------------------------------------------------
WORKSPACE_RESUME_HINT=""
WORKSPACE_CACHE="${PWD}/.unitares/session.json"
if [[ -f "${WORKSPACE_CACHE}" ]]; then
  WORKSPACE_RESUME_HINT=$(python3 - "${WORKSPACE_CACHE}" <<'PY' 2>/dev/null || true
import json, sys
from pathlib import Path

cache = Path(sys.argv[1])
try:
    data = json.loads(cache.read_text(encoding="utf-8"))
except Exception:
    sys.exit(0)

if not data.get("continuity_token"):
    sys.exit(0)

label = data.get("display_name") or data.get("agent_id") or ""
ts = data.get("updated_at", "")
date_part = ts[:10] if ts else ""
suffix = f" (last active {date_part})" if date_part else ""
print(
    "This workspace has a prior continuity_token cached at "
    "./.unitares/session.json"
    + (f" for {label}" if label else "")
    + suffix
    + ". To resume that identity, call:\n"
    "    onboard(continuity_token=<value from ./.unitares/session.json>)\n"
    "Otherwise call onboard(force_new=true) to mint a fresh identity for "
    "this run — a bare onboard() can pin-resume an unrelated prior agent."
)
PY
)
fi

# ---------------------------------------------------------------------------
# Ping governance server
# ---------------------------------------------------------------------------
HEALTH_STATUS=$(curl -s --max-time 3 "${SERVER_URL}/health" 2>/dev/null || echo "")

if [[ -z "${HEALTH_STATUS}" ]]; then
  CONTEXT="UNITARES Governance: OFFLINE (${SERVER_URL} unreachable). Agent not onboarded. Governance tools may be unavailable."
  if [[ -n "${SKILL_CONTENT}" ]]; then
    CONTEXT="${CONTEXT}

--- Governance Fundamentals (reference) ---
${SKILL_CONTENT}"
  fi
else
  CONTEXT="UNITARES Governance: ONLINE

No identity has been created on your behalf. Your MCP stdio transport is
unbound. As your first governance tool call, invoke:

    onboard(purpose=\"<what you're doing>\", force_new=true)

\`force_new=true\` is load-bearing: without it, the server may pin-resume
a prior agent's identity by IP:UA fingerprint alone on shared hosts (see
PATH 2 observation in the UNITARES server). Pass it whenever you do NOT
have a continuity_token for this workspace.

The post-identity hook records UUID + continuity_token locally so follow-up
tool calls (/checkin, auto-checkin on edits) can find your session.

If you need to recover a specific prior identity by UUID, that is an
operator action — run /diagnose for guided recovery rather than guessing
a UUID."

  if [[ -n "${WORKSPACE_RESUME_HINT}" ]]; then
    CONTEXT="${CONTEXT}

${WORKSPACE_RESUME_HINT}"
  fi

  if [[ -n "${SKILL_CONTENT}" ]]; then
    CONTEXT="${CONTEXT}

--- Governance Fundamentals (excerpt) ---
${SKILL_CONTENT}"
  fi
fi

ESCAPED_CONTEXT="$(escape_for_json "${CONTEXT}")"
cat <<ENDJSON
{
  "additional_context": "${ESCAPED_CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ESCAPED_CONTEXT}"
  }
}
ENDJSON
