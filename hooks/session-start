#!/usr/bin/env bash
# UNITARES Governance Plugin — SessionStart hook
#
# Identity-honesty Part C (Session C, 2026-04-17):
# This hook no longer creates an identity on the agent's behalf. It confirms
# governance is reachable, loads the fundamentals skill, and emits context
# instructing the agent to make its own first MCP tool call (onboard /
# identity / bind_session). The post-identity PostToolUse hook captures the
# response and writes the session cache.
#
# See docs/specs/2026-04-17-session-start-stops-creating-identities.md
# in the unitares repo for the architectural rationale.
set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve plugin root and helpers
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

DEFAULTS_FILE=""
for candidate in \
  "${PLUGIN_ROOT}/config/defaults.env" \
  "${PLUGIN_ROOT}/config/client/defaults.env"
do
  if [[ -f "${candidate}" ]]; then
    DEFAULTS_FILE="${candidate}"
    break
  fi
done

FRESHNESS_WARNING_HELPER=""
for candidate in \
  "${PLUGIN_ROOT}/scripts/_freshness_warning.py" \
  "${PLUGIN_ROOT}/scripts/client/_freshness_warning.py"
do
  if [[ -f "${candidate}" ]]; then
    FRESHNESS_WARNING_HELPER="${candidate}"
    break
  fi
done

# Preserve operator-provided env overrides across defaults.env sourcing.
SERVER_URL_OVERRIDE="${UNITARES_SERVER_URL-}"
if [[ -n "${DEFAULTS_FILE}" ]]; then
  # shellcheck source=/dev/null
  source "${DEFAULTS_FILE}"
fi
if [[ -n "${SERVER_URL_OVERRIDE}" ]]; then
  UNITARES_SERVER_URL="${SERVER_URL_OVERRIDE}"
fi

SERVER_URL="${UNITARES_SERVER_URL:-http://localhost:8767}"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
escape_for_json() {
  python3 -c "
import json, sys
print(json.dumps(sys.argv[1])[1:-1])
" "$1"
}

# ---------------------------------------------------------------------------
# Load a short reference snippet (available regardless of server status)
# ---------------------------------------------------------------------------
SKILL_CONTENT=""
SKILL_FILE="${PLUGIN_ROOT}/skills/governance-fundamentals/SKILL.md"
if [[ -f "${SKILL_FILE}" ]]; then
  SKILL_CONTENT="$(sed -n '1,80p' "${SKILL_FILE}")"
fi

if [[ -n "${SKILL_CONTENT}" && -n "${FRESHNESS_WARNING_HELPER}" ]]; then
  FRESHNESS_WARNING=$(python3 "${FRESHNESS_WARNING_HELPER}" "${SKILL_CONTENT}" 2>/dev/null || true)
  if [[ -n "${FRESHNESS_WARNING}" ]]; then
    SKILL_CONTENT="${FRESHNESS_WARNING}

${SKILL_CONTENT}"
  fi
fi

# ---------------------------------------------------------------------------
# Workspace-local lineage probe — slot-scoped only.
#
# IMPORTANT: we deliberately do NOT enumerate ~/.unitares/session-*.json.
# That glob produced an unfiltered cross-instance UUID menu, which — paired
# with an `identity(agent_uuid=..., resume=true)` suggestion — invited
# fresh agents to pattern-match on model name and resume into other
# instances' identities. See KG bug 2026-04-20T00:09:51.
#
# We also deliberately do NOT read the bare ./.unitares/session.json.
# The "owned by the process-instance that previously ran in THIS directory"
# assumption breaks when the workspace is shared across concurrent claude
# processes — notably the discord-dispatch case, where threads defaulting
# to cwd=HOME all shared /Users/cirwel/.unitares/session.json and silently
# funneled onto whichever agent last wrote the cache. That's the flaw
# this hook is tightening against; the dispatch-side fix (per-thread
# scratch dirs) is complementary, not redundant.
#
# The slot-scoped cache ./.unitares/session-<claude_session_id>.json, by
# contrast, is owned by one specific claude process session. On --resume
# it matches; a fresh session writes its own. Under the identity ontology
# (unitares/docs/ontology/identity.md) its UUID is surfaced as a *lineage
# candidate* — the predecessor this fresh process declares via
# `parent_agent_id` — NOT as a resume credential.
# ---------------------------------------------------------------------------
WORKSPACE_LINEAGE_HINT=""
CLAUDE_SESSION_ID=""
# Claude Code sends the hook event as JSON on stdin, including session_id.
if [[ ! -t 0 ]]; then
  SESSION_START_STDIN=$(cat 2>/dev/null) || SESSION_START_STDIN=""
  if [[ -n "${SESSION_START_STDIN}" ]]; then
    CLAUDE_SESSION_ID=$(python3 - "${SESSION_START_STDIN}" <<'PY' 2>/dev/null || true
import json, sys
try:
    data = json.loads(sys.argv[1])
    print((data.get("session_id") or "").strip())
except Exception:
    pass
PY
    )
  fi
fi

WORKSPACE_CACHE=""
if [[ -n "${CLAUDE_SESSION_ID}" ]]; then
  # Match session_cache.py _slot_suffix: alnum + [-_], cap at 64 chars.
  SAFE_SLOT=$(python3 - "${CLAUDE_SESSION_ID}" <<'PY' 2>/dev/null || true
import sys
raw = sys.argv[1]
safe = "".join(c if c.isalnum() or c in ("-", "_") else "_" for c in raw)
print(safe[:64])
PY
  )
  if [[ -n "${SAFE_SLOT}" ]]; then
    WORKSPACE_CACHE="${PWD}/.unitares/session-${SAFE_SLOT}.json"
  fi
fi

# ---------------------------------------------------------------------------
# Compact mode — when this workspace already has a fresh slot-scoped cache
# (mtime < 1h), the agent has almost certainly seen the full Fundamentals
# excerpt and the long onboard-prose this hour. Per-turn SessionStart
# resume events fire frequently in normal Claude Code use; re-injecting
# the full ~3KB context every fire is repetition without information.
# We collapse to a one-line prompt and skip the Fundamentals block.
#
# The trigger is intentionally workspace-scoped — fresh workspaces
# (no cache yet) get the full onboarding prose, which is the right
# default for an agent that hasn't seen it.
# ---------------------------------------------------------------------------
COMPACT_MODE=0
COMPACT_TTL_SECS="${UNITARES_HOOK_COMPACT_TTL:-3600}"
if [[ -n "${WORKSPACE_CACHE}" && -f "${WORKSPACE_CACHE}" ]]; then
  # Portable mtime: BSD `stat -f %m` (macOS) → fallback to GNU `stat -c %Y` (Linux).
  CACHE_MTIME=$(stat -f %m "${WORKSPACE_CACHE}" 2>/dev/null || stat -c %Y "${WORKSPACE_CACHE}" 2>/dev/null || echo 0)
  CACHE_AGE_SECS=$(( $(date +%s) - CACHE_MTIME ))
  if (( CACHE_MTIME > 0 && CACHE_AGE_SECS >= 0 && CACHE_AGE_SECS < COMPACT_TTL_SECS )); then
    COMPACT_MODE=1
  fi
fi

if [[ -n "${WORKSPACE_CACHE}" && -f "${WORKSPACE_CACHE}" ]]; then
  WORKSPACE_LINEAGE_HINT=$(python3 - "${WORKSPACE_CACHE}" <<'PY' 2>/dev/null || true
import json, sys
from pathlib import Path

cache = Path(sys.argv[1])
try:
    data = json.loads(cache.read_text(encoding="utf-8"))
except Exception:
    sys.exit(0)

uuid = (data.get("uuid") or data.get("agent_uuid") or "").strip()
if not uuid:
    sys.exit(0)

label = data.get("display_name") or data.get("agent_id") or ""
ts = data.get("updated_at", "")
date_part = ts[:10] if ts else ""

header = "A prior process-instance ran in this workspace"
if label:
    header += f" as {label}"
if date_part:
    header += f" (last active {date_part})"
header += f"; UUID `{uuid}`."

print(
    header + "\n\nUnder the identity ontology "
    "(unitares/docs/ontology/identity.md), a fresh process-instance "
    "declares lineage rather than resuming identity. To record the "
    "inheritance chain, include in the onboard call below:\n"
    f"    parent_agent_id=\"{uuid}\", spawn_reason=\"new_session\"\n"
    "Memory, KG notes, and self-knowledge persist across instances; "
    "governance-identity does not."
)
PY
)
fi

# ---------------------------------------------------------------------------
# Ping governance server
# ---------------------------------------------------------------------------
HEALTH_LOG="${UNITARES_SESSION_START_LOG:-/tmp/unitares-session-start.log}"
HEALTH_EXIT=0
HEALTH_STATUS=$(curl -sS --max-time 3 "${SERVER_URL}/health" 2>>"${HEALTH_LOG}") || HEALTH_EXIT=$?
printf '[%s] curl exit=%d len=%d url=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "${HEALTH_EXIT}" "${#HEALTH_STATUS}" "${SERVER_URL}/health" >> "${HEALTH_LOG}" 2>/dev/null || true

if [[ -z "${HEALTH_STATUS}" ]]; then
  CONTEXT="UNITARES Governance: OFFLINE (${SERVER_URL} unreachable). Agent not onboarded. Governance tools may be unavailable."
  if [[ -n "${SKILL_CONTENT}" ]]; then
    CONTEXT="${CONTEXT}

--- Governance Fundamentals (reference) ---
${SKILL_CONTENT}"
  fi
else
  if [[ "${COMPACT_MODE}" == "1" ]]; then
    # Compact prose: assumes the agent saw the full prompt + Fundamentals
    # excerpt earlier this hour (workspace cache mtime < TTL). Keep
    # `force_new=true` (force_new pin-resume guard, regression-tested),
    # the ontology pointer (so a forgetful agent can re-read), and the
    # operator escape hatch — drop everything else.
    CONTEXT="UNITARES Governance: ONLINE
Fresh process-instance, MCP stdio unbound. Onboard with \`force_new=true\` (declare \`parent_agent_id\` if continuing prior workspace work — see lineage hint below).
Ontology: unitares/docs/ontology/identity.md  ·  Recovery: run /diagnose."
  else
    CONTEXT="UNITARES Governance: ONLINE

No identity has been created on your behalf. Your MCP stdio transport is
unbound. As your first governance tool call, invoke:

    onboard(purpose=\"<what you're doing>\", force_new=true)

Under the identity ontology (unitares/docs/ontology/identity.md), fresh
process-instances mint fresh governance-identity. \`force_new=true\` is
the default posture; lineage, when applicable, is declared via
\`parent_agent_id\` rather than resumed via token.

The post-identity hook records UUID locally so follow-up tool calls
(/checkin, auto-checkin on edits) can find your session.

If you need to recover a specific prior identity by UUID, that is an
operator action — run /diagnose for guided recovery rather than guessing
a UUID."
  fi

  if [[ -n "${WORKSPACE_LINEAGE_HINT}" ]]; then
    CONTEXT="${CONTEXT}

${WORKSPACE_LINEAGE_HINT}"
  fi

  # Skip the Fundamentals excerpt in compact mode. The freshness warning
  # (if any) still injects on the *next* fresh-workspace fire when the
  # full block returns, so calibration on stale skill files isn't lost.
  if [[ "${COMPACT_MODE}" != "1" && -n "${SKILL_CONTENT}" ]]; then
    CONTEXT="${CONTEXT}

--- Governance Fundamentals (excerpt) ---
${SKILL_CONTENT}"
  fi
fi

ESCAPED_CONTEXT="$(escape_for_json "${CONTEXT}")"
cat <<ENDJSON
{
  "additional_context": "${ESCAPED_CONTEXT}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ESCAPED_CONTEXT}"
  }
}
ENDJSON
