#!/usr/bin/env bash
# UNITARES Governance Plugin — PostToolUse hook (Edit/Write)
#
# Responsibilities (in order):
#   1. Fan edit event out to an optional workspace-local watcher hook.
#   2. Bump the milestone accumulator (edit_count, files_touched, timestamps).
#   3. If edit_count or elapsed-since-last-checkin crosses a threshold, fire
#      process_agent_update against the governance server as a hook-driven
#      auto-checkin, then reset the accumulator.
#
# This revives the auto-checkin behavior that existed before commit e46f25d
# ("Align plugin with Codex packaging and runtime semantics"). That refactor
# stripped the per-edit curl but never replaced the forcing function, which
# left Claude in the same explicit-only mode as Codex even though Claude can
# drive richer hook behavior. Codex keeps its /checkin workflow untouched.
#
# Config (all optional):
#   UNITARES_AUTO_CHECKIN_ENABLED=0   — disable auto-checkin entirely
#   UNITARES_AUTO_CHECKIN_EDITS=5     — fire after N edits since last checkin
#   UNITARES_AUTO_CHECKIN_SECS=600    — fire after T seconds since last checkin
#                                       (combined with edit_count >= 1)
#   UNITARES_WATCHER_HOOK=<path>      — custom watcher hook path
#   UNITARES_WATCHER_ENABLED=0        — disable watcher fan-out
#
# Runs async — must never block or produce output on failure.
set -uo pipefail

# ---------------------------------------------------------------------------
# Resolve plugin root and helpers
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

SESSION_CACHE_HELPER=""
for candidate in \
  "${PLUGIN_ROOT}/scripts/session_cache.py" \
  "${PLUGIN_ROOT}/scripts/client/session_cache.py"
do
  if [[ -f "${candidate}" ]]; then
    SESSION_CACHE_HELPER="${candidate}"
    break
  fi
done

DEFAULTS_FILE=""
for candidate in \
  "${PLUGIN_ROOT}/config/defaults.env" \
  "${PLUGIN_ROOT}/config/client/defaults.env"
do
  if [[ -f "${candidate}" ]]; then
    DEFAULTS_FILE="${candidate}"
    break
  fi
done

SERVER_URL_OVERRIDE="${UNITARES_SERVER_URL-}"
if [[ -n "${DEFAULTS_FILE}" ]]; then
  # shellcheck source=/dev/null
  source "${DEFAULTS_FILE}" 2>/dev/null || true
fi
if [[ -n "${SERVER_URL_OVERRIDE}" ]]; then
  UNITARES_SERVER_URL="${SERVER_URL_OVERRIDE}"
fi
SERVER_URL="${UNITARES_SERVER_URL:-http://localhost:8767}"

# ---------------------------------------------------------------------------
# Read hook input from stdin (Claude passes tool info as JSON)
# ---------------------------------------------------------------------------
HOOK_INPUT=""
if [[ ! -t 0 ]]; then
  HOOK_INPUT=$(cat 2>/dev/null) || true
fi

# ---------------------------------------------------------------------------
# Optional workspace-local watcher fan-out
# ---------------------------------------------------------------------------
WATCHER_HOOK="${UNITARES_WATCHER_HOOK:-${PWD}/agents/watcher/watcher-hook.sh}"
if [[ "${UNITARES_WATCHER_ENABLED:-1}" != "0" && -x "${WATCHER_HOOK}" && -n "${HOOK_INPUT}" ]]; then
  printf '%s' "${HOOK_INPUT}" | "${WATCHER_HOOK}" >/dev/null 2>&1 &
fi

# ---------------------------------------------------------------------------
# Require the session cache helper + an active session to do anything else
# ---------------------------------------------------------------------------
if [[ -z "${SESSION_CACHE_HELPER}" ]]; then
  exit 0
fi

SESSION_PAYLOAD=$(python3 "${SESSION_CACHE_HELPER}" get session --workspace "${PWD}" 2>/dev/null || echo "{}")
if [[ -z "${SESSION_PAYLOAD}" || "${SESSION_PAYLOAD}" == "{}" ]]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Extract file_path from the Edit/Write tool payload
# ---------------------------------------------------------------------------
FILE_PATH=$(python3 - "${HOOK_INPUT}" <<'PY' 2>/dev/null || true
import json, sys
raw = sys.argv[1] if len(sys.argv) > 1 else ""
try:
    data = json.loads(raw) if raw else {}
except Exception:
    data = {}
tool_input = data.get("tool_input", data.get("input", data))
print(tool_input.get("file_path", tool_input.get("path", "")))
PY
)

# ---------------------------------------------------------------------------
# Bump the milestone accumulator (always — this is what /checkin summarizes)
# ---------------------------------------------------------------------------
MILESTONE_PAYLOAD=$(python3 "${SESSION_CACHE_HELPER}" \
  bump-edit \
  --workspace "${PWD}" \
  --file-path "${FILE_PATH}" \
  --echo 2>/dev/null || echo "{}")

if [[ -z "${MILESTONE_PAYLOAD}" || "${MILESTONE_PAYLOAD}" == "{}" ]]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Auto-checkin decision
# ---------------------------------------------------------------------------
if [[ "${UNITARES_AUTO_CHECKIN_ENABLED:-1}" == "0" ]]; then
  exit 0
fi

EDIT_THRESHOLD="${UNITARES_AUTO_CHECKIN_EDITS:-5}"
SECS_THRESHOLD="${UNITARES_AUTO_CHECKIN_SECS:-600}"

DECISION_HELPER=""
for candidate in \
  "${PLUGIN_ROOT}/scripts/auto_checkin_decision.py" \
  "${PLUGIN_ROOT}/scripts/client/auto_checkin_decision.py"
do
  if [[ -f "${candidate}" ]]; then
    DECISION_HELPER="${candidate}"
    break
  fi
done

if [[ -z "${DECISION_HELPER}" ]]; then
  exit 0
fi

DECISION=$(python3 "${DECISION_HELPER}" \
  --session-json "${SESSION_PAYLOAD}" \
  --milestone-json "${MILESTONE_PAYLOAD}" \
  --edit-threshold "${EDIT_THRESHOLD}" \
  --secs-threshold "${SECS_THRESHOLD}" 2>/dev/null || echo "{}")

FIRE=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('fire', False))" "${DECISION}" 2>/dev/null || echo "False")
if [[ "${FIRE}" != "True" ]]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Fire process_agent_update — routes through scripts/checkin.py so it gets
# redaction, logging, the kill switch, and metadata tagging on equal footing
# with session-start/stop/end check-ins.
# ---------------------------------------------------------------------------
CONTINUITY_TOKEN=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('continuity_token',''))" "${DECISION}" 2>/dev/null || echo "")
CLIENT_SESSION_ID=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('client_session_id',''))" "${DECISION}" 2>/dev/null || echo "")
RESPONSE_TEXT=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('response_text',''))" "${DECISION}" 2>/dev/null || echo "")
COMPLEXITY=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('complexity',0.3))" "${DECISION}" 2>/dev/null || echo "0.3")

if [[ -z "${CONTINUITY_TOKEN}" && -z "${CLIENT_SESSION_ID}" ]]; then
  exit 0
fi

# Pull uuid + slot from the session cache for diagnostic logging.
# Not strictly required for governance — checkin.py needs --slot, and --uuid
# only shows in the local log prefix.
SESSION_JSON="${PWD}/.unitares/session.json"
[[ ! -f "${SESSION_JSON}" ]] && SESSION_JSON="${HOME}/.unitares/session.json"
if [[ -f "${SESSION_JSON}" ]]; then
  SLOT=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('slot','default'))" "${SESSION_JSON}" 2>/dev/null || echo "default")
  UUID_HINT=$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('uuid',''))" "${SESSION_JSON}" 2>/dev/null || echo "")
else
  SLOT="default"
  UUID_HINT=""
fi

# NOTE: The previous inline curl supported UNITARES_HTTP_API_TOKEN as a Bearer
# token; scripts/checkin.py does not (yet). Local deployments — the only
# supported configuration today — do not use API-token auth, so this is not
# a regression in practice. Add --bearer-token support to checkin.py if
# token-authenticated governance endpoints are needed in the future.
python3 "${PLUGIN_ROOT}/scripts/checkin.py" \
  --event auto_edit \
  --response-text "${RESPONSE_TEXT}" \
  --complexity "${COMPLEXITY}" \
  --confidence 0.6 \
  --client-session-id "${CLIENT_SESSION_ID}" \
  --continuity-token "${CONTINUITY_TOKEN}" \
  --uuid "${UUID_HINT}" \
  --slot "${SLOT}" \
  >/dev/null 2>&1 || true

# Reset the accumulator + stamp last_checkin_ts. checkin.py logs success/fail
# locally; from the hook's perspective the attempt is fire-and-forget — we
# always reset so the next edit starts a fresh accumulator window rather than
# double-firing on counters that may already have been committed server-side.
python3 "${SESSION_CACHE_HELPER}" \
  reset-milestone \
  --workspace "${PWD}" >/dev/null 2>&1 || true

NOW_EPOCH=$(python3 -c "import time; print(int(time.time()))")
python3 "${SESSION_CACHE_HELPER}" \
  set session \
  --workspace "${PWD}" \
  --merge \
  --stamp \
  --json "{\"last_checkin_ts\": ${NOW_EPOCH}}" >/dev/null 2>&1 || true

exit 0
