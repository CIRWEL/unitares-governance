#!/usr/bin/env bash
# UNITARES Governance Plugin — PostToolUse hook (Edit/Write)
# Local milestone capture: records recent edit context without auto-checking in
# Runs async — must never block or produce output on failure
set -uo pipefail

# ---------------------------------------------------------------------------
# Read cached session
# ---------------------------------------------------------------------------
SESSION_FILE="${PWD}/.claude/unitares-session.json"
MILESTONE_FILE="${PWD}/.claude/unitares-last-edit.json"

if [[ ! -f "${SESSION_FILE}" ]]; then
  exit 0
fi

# ---------------------------------------------------------------------------
# Read hook input from stdin (Claude passes tool info as JSON)
# ---------------------------------------------------------------------------
HOOK_INPUT=""
if [[ ! -t 0 ]]; then
  HOOK_INPUT=$(cat 2>/dev/null) || true
fi

python3 - "${HOOK_INPUT}" "${MILESTONE_FILE}" <<'PY' >/dev/null 2>&1 || true
import json
import os
import sys
import time

raw = sys.argv[1] if len(sys.argv) > 1 else ""
out = sys.argv[2] if len(sys.argv) > 2 else ""

try:
    data = json.loads(raw) if raw else {}
except Exception:
    data = {}

tool_input = data.get("tool_input", data.get("input", data))
file_path = tool_input.get("file_path", tool_input.get("path", ""))

payload = {
    "timestamp": int(time.time()),
    "file_path": file_path,
    "event": "edit",
}

if out:
    os.makedirs(os.path.dirname(out), exist_ok=True)
    with open(out, "w", encoding="utf-8") as f:
        json.dump(payload, f, indent=2)
PY

exit 0
